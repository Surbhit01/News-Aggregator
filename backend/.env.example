# ── Application ──────────────────────────────────────────
DEBUG=true
APP_NAME="News Aggregator"

# ── Database ─────────────────────────────────────────────
# SQLite (local dev):
DATABASE_URL="sqlite:///./news_aggregator.db"
# PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@localhost:5432/news_aggregator"

# ── Redis ────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ── LLM Provider ─────────────────────────────────────────
# Set LLM_ENABLED=false to use extractive-only summaries (no API calls)
# Great for testing without consuming credits
LLM_ENABLED=true

# API key — required for cloud providers, optional for local Ollama
LLM_API_KEY=""

# Model name
#   OpenAI:    gpt-4o-mini, gpt-4o, gpt-4-turbo
#   Ollama:    llama3.2, mistral, qwen2.5
#   Kimi:      moonshot-v1-8k, moonshot-v1-32k
#   DeepSeek:  deepseek-chat
LLM_MODEL="gpt-4o-mini"

# Base URL — uncomment for non-OpenAI providers:
# Ollama:   LLM_BASE_URL="http://localhost:11434/v1"
# Kimi:     LLM_BASE_URL="https://api.moonshot.cn/v1"
# DeepSeek: LLM_BASE_URL="https://api.deepseek.com/v1"
# LLM_BASE_URL=""

# ── JWT ──────────────────────────────────────────────────
SECRET_KEY="change-me-to-a-secure-random-key"